# ============================================================
# VARIÁVEIS DE AMBIENTE - copie para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# ============================================================

# Evolution API (WhatsApp) — OBRIGATÓRIAS para integração WhatsApp
EVOLUTION_API_URL=https://sua-evolution-api.example.com
EVOLUTION_API_KEY=your-evolution-api-key-here
EVOLUTION_INSTANCE_NAME=Cop Rede
EVOLUTION_SOURCE_CHAT_ID=5511999999999@g.us

# JSONBin.io — OBRIGATÓRIAS para persistência de dados
# Obtenha em https://jsonbin.io → API Keys
JSONBIN_MASTER_KEY=your-jsonbin-master-key
JSONBIN_ACCESS_KEY=your-jsonbin-access-key
# Bin separado para mensagens do WhatsApp
WHATSAPP_BIN_ID=your-whatsapp-bin-id

# Alocação de HUB — OBRIGATÓRIAS se usar módulo HUB
ALOCACAO_HUB_MASTER_KEY=your-hub-master-key
ALOCACAO_HUB_ACCESS_KEY=your-hub-access-key
ALOCACAO_HUB_CHAT_ID=120363420668199320@g.us
ALOCACAO_HUB_BIN_ID=

# COP REDE EMPRESARIAL
COP_REDE_EMPRESARIAL_CHAT_ID=120363423786613991@g.us

# Supabase — obrigatória para endpoint /api/matriz-ofensores
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Token para endpoints de diagnóstico (/api/diagnostico/*)
# Gere um valor aleatório forte, ex: openssl rand -hex 32
ADMIN_DIAG_TOKEN=your-random-secret-token-here

# Servidor
PORT=3001
# Lista de origens permitidas no CORS (separe por vírgula)
# Em produção, substitua '*' pelo(s) domínio(s) real(is)
CORS_ORIGIN=http://localhost:3001,http://localhost:5500
